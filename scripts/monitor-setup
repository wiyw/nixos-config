#!/usr/bin/env bash
sleep 1

MONITORS=$(hyprctl monitors -j | jq -r '.[].name')

if echo "$MONITORS" | grep -q "^DP-4$"; then
    # External monitor connected - set up dual monitor
    hyprctl keyword monitor "DP-4, preferred, 0x0, 1"
    hyprctl keyword monitor "eDP-1, preferred, 1920x0, 1"
    # Assign workspaces to monitors
    for i in $(seq 1 10); do
        hyprctl keyword workspace "$i, monitor:DP-4"
    done
    for i in $(seq 11 20); do
        hyprctl keyword workspace "$i, monitor:eDP-1"
    done
else
    # Laptop only - set eDP-1 at 0x0, workspaces on eDP-1
    hyprctl keyword monitor "eDP-1, preferred, 0x0, 1"
    for i in $(seq 1 20); do
        hyprctl keyword workspace "$i, monitor:eDP-1"
    done
fi